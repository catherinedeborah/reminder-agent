# ==============================================================================
# AI REMINDER AGENT CONFIGURATION ENVIRONMENT FILE
# ==============================================================================
# Rename this file to '.env' and fill in the parameters for real integrations.

# --- Database config ---
# Defaults to sqlite inside the workspace.
DATABASE_URL=sqlite:///./reminder.db

# --- Jira integration ---
JIRA_BASE_URL=https://your-jira-domain.atlassian.net
JIRA_PAT_TOKEN=your_jira_personal_access_token_here

# --- Slack integration ---
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here

# --- SMTP Email config ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=no-reply@yourdomain.com

# --- LLM Endpoint config ---
VLLM_API_BASE=http://localhost:8100/v1
VLLM_API_KEY=your_vllm_api_key
MODEL_NAME=google/gemma-4-E4B-it
MOCK_LLM=true
